{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "metals": {
      "type": "remote",
      "url": "http://127.0.0.1:33215/mcp",
      "enabled": true,
    },
    "browsermcp": {
      "type": "local",
      "command": ["npx", "@browsermcp/mcp@latest"],
      "enabled": true
    }
  },
}